# Required: API key for OpenCode AI
OPENCODE_API_KEY=

# Optional: OpenCode AI API base URL
# Default: https://opencode.ai/zen/v1/chat/completions
OPENCODE_BASE_URL=https://opencode.ai/zen/v1/chat/completions

# Optional: Server port
# Default: 3001
PORT=3001

# Optional: CORS allowed origins (comma-separated)
# Default: http://localhost:5173,http://localhost:3001,https://eztriqs21.github.io
CORS_ORIGINS=http://localhost:5173,http://localhost:3001,https://eztriqs21.github.io

# Frontend only (Vite):
# VITE_API_BASE=http://localhost:3001/api
